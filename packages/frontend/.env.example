# Local browsing: https://www.mocco.work (traefik+mkcert, hosts). prod: https://www.mocco.club (ADR 0006)
AUTH_URL=https://www.mocco.work
# openssl rand -base64 32
AUTH_SECRET=

DATABASE_URL=postgres://mocco:mocco@localhost:5432/mocco

# Sentry — leave empty to disable (SDK becomes a no-op). Same project, two keys:
# server (SENTRY_DSN) and client (NEXT_PUBLIC_SENTRY_DSN). Optional override:
# NEXT_PUBLIC_ENVIRONMENT=Local|Dev|Prod (else derived from VERCEL_ENV).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
