# Local browsing: https://www.mocco.work (traefik+mkcert, hosts). prod: https://www.mocco.club (ADR 0006)
AUTH_URL=https://www.mocco.work
# openssl rand -base64 32
AUTH_SECRET=

DATABASE_URL=postgres://mocco:mocco@localhost:5432/mocco

# Sentry — leave empty to disable (SDK becomes a no-op). One value for client and
# server (the DSN is public, shipped in the client bundle). Optional environment
# override: NEXT_PUBLIC_ENVIRONMENT=Local|Dev|Prod (else derived from VERCEL_ENV).
NEXT_PUBLIC_SENTRY_DSN=

# Debug/verification endpoints (/debug/*, /api/debug/*, debug tRPC). Off unless
# set to 'true' — opt in per environment to re-verify Sentry, then unset.
NEXT_PUBLIC_DEBUG=

# GitHub App (slice 3a connect/manage). Optional — leave empty to keep booting
# without GitHub configured.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# base64 of a PKCS#8 PEM private key: openssl pkcs8 -topk8 -nocrypt
GITHUB_APP_PRIVATE_KEY_B64=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
