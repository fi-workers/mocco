{
  "$id": "https://mocco.club/mocco.schema.json",
  "title": ".mocco.yml (v1)",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "pipeline": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "run": {
            "type": "string",
            "minLength": 1
          },
          "executor": {
            "type": "string",
            "minLength": 1
          },
          "with": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "run",
          "executor"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "pipeline",
    "steps"
  ],
  "additionalProperties": false
}
